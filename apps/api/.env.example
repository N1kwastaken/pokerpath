# ─── Servidor ────────────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ─── Banco de dados ──────────────────────────────────────────
# Desenvolvimento local: SQLite (arquivo em prisma/dev.db).
DATABASE_URL="file:./dev.db"
# Produção (PRD 15.2): PostgreSQL — trocar o provider em prisma/schema.prisma.
# DATABASE_URL="postgresql://pokerpath:pokerpath@localhost:5432/pokerpath?schema=public"

# ─── JWT (PRD seção 15.5) ────────────────────────────────────
# Gere segredos fortes em produção: openssl rand -base64 48
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ────────────────────────────────────────────────────
WEB_ORIGIN="http://localhost:5173"
