# ─── Servidor ────────────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ─── Banco de dados ──────────────────────────────────────────
# Desenvolvimento local: SQLite (arquivo em prisma/dev.db).
DATABASE_URL="file:./dev.db"
# Produção (PRD 15.2): PostgreSQL — trocar o provider em prisma/schema.prisma.
# DATABASE_URL="postgresql://pokerpath:pokerpath@localhost:5432/pokerpath?schema=public"

# ─── JWT (PRD seção 15.5) ────────────────────────────────────
# Gere segredos fortes em produção: openssl rand -base64 48
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ────────────────────────────────────────────────────
WEB_ORIGIN="http://localhost:5173"

# ─── E-mail ──────────────────────────────────────────────────
# 'console' (padrão): o e-mail é impresso no log da API, nada é enviado —
# é assim que se copia o link de redefinir senha em dev.
# 'resend': envia de verdade (exige RESEND_API_KEY e MAIL_FROM).
MAIL_DRIVER="console"
# RESEND_API_KEY="re_..."
# MAIL_FROM="PokerPath <ola@seudominio.com>"

# ─── Tarefa agendada ─────────────────────────────────────────
# Segredo do lembrete diário de streak:
#   curl -X POST -H "x-cron-secret: SEGREDO" .../api/jobs/streak-reminder
# Sem CRON_SECRET a rota fica desligada.
# CRON_SECRET="um-segredo-longo-e-aleatorio"
